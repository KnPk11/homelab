# Gemini CLI Ignore File
# Prevents memory errors by excluding large or irrelevant directories from indexing.
# These rules apply to Gemini CLI when scanning your codebase.

# Hidden directories with high volume
.npm/
.cache/
.vscode-server/
.local/
.config/
.opencode/
.ssh/
.git/
node_modules/
bower_components/

# System-level large directories (when root is included)
/proc/
/sys/
/dev/
/run/
/var/log/
/var/cache/
/var/lib/docker/
/tmp/

# Media and massive storage (excluded from indexing to save memory)
/mnt/
/data/

# General noise
**/*.log
**/logs/
**/*.tmp
**/*.bak
**/*.swp
**/.DS_Store
Thumbs.db
