vaultwarden.{$DOMAIN_NAME} {
    import common-headers
    import common-robots
    import access_policy_wan 100 30s
    import common-logging-plaintext vaultwarden
    import common-logging vaultwarden

    # Add the EXTRA header just for this site
    header {
        # Prevent your site from being embedded in an iframe (Clickjacking protection)
        X-Frame-Options "SAMEORIGIN"
    }

    # Block external access to the Admin panel
    # Returns 404 to confuse scanners (or use 403 Forbidden)
    @admin {
        path /admin*
        not remote_ip 192.168.50.0/24 10.0.0.0/8
    }
    respond @admin "Unauthorized" 403

    # Proxy to Vaultwarden
    # reverse_proxy vaultwarden:80 {
    reverse_proxy {$HOMELAB_IP}:9103 {
        # Pass the real client IP so Vaultwarden can rate-limit correctly
        header_up X-Real-IP {remote_host}
    }
}

