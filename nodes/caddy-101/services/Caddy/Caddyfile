# Caddyfile v3.0 - Core Homelab Proxy
# ---- snippets ----

# ---- 🌐 ACCESS + RATE LIMIT SNIPPET ----
# LAN‑only access policy
(access_policy_lan) {
    @not_lan {
        not remote_ip 192.168.88.0/24 192.168.50.0/24 172.16.0.0/12 10.5.0.0/24 10.6.0.0/24 100.64.0.0/10 ::1 fe80::/10 {$IPV6_PREFIX}
    }
    handle @not_lan {
        respond "LAN party only." 403
    }
}

# WAN-allowed access policy (no IP restriction, but rate-limited for WAN)
(access_policy_wan) {

    # Define a matcher for WAN (non-LAN) IPs
    # This uses the same logic from your (access_policy_lan) snippet
    @wan {
        not remote_ip 192.168.88.0/24 192.168.50.0/24 172.16.0.0/12 10.5.0.0/24 10.6.0.0/24 100.64.0.0/10 ::1 fe80::/10 {$IPV6_PREFIX}
    }

    # Apply the rate limit ONLY to traffic that matches @wan
    rate_limit @wan {
        zone wan_zone {
            key {http.request.remote_ip}
            events {args[0]}
            window {args[1]}
        }
    }

    # WAN kill-switch (uncomment to block all WAN traffic)
    # handle @wan {
    #    respond "Public access temporarily disabled" 403
    # }
}

# ---- Honeypots & Sensitive File Traps ----
(honeypots-and-traps) {
    # Common honeypot paths (fake admin panels, CMS logins, etc.)
    @honeypots {
        path /admin/* /user/* /phpmyadmin/* /cgi-bin/* /wp-admin/* /wp-login.php* /xmlrpc.php
        path /typo3/* /drupal/* /joomla/administrator/* /pgadmin4/* /adminer.php
    }
    handle @honeypots {
        respond "Unauthorized" 403
        # bogus user to trip scanners
        basic_auth {
            user fakeuser
        }
    }

    # Sensitive files often probed by bots
    @sensitive {
        path /config.cfg /.env /id_rsa /server-status /etc/passwd
        path /.git/* /composer.json /package.json /Dockerfile
        path /wp-config.php /db.sql /backup.zip /backup.tar.gz /db_backup.sql.gz
        path /config.php /local.xml /settings.py
    }
    handle @sensitive {
        respond "Unauthorized" 401
    }
}

(common-headers) {
    encode zstd gzip
    header {
        # Enable XSS protection
        X-X-SS-Protection "1; mode=block"
        # Prevent MIME type sniffing
        X-Content-Type-Options "nosniff"
        # Prevents your site from being embedded in iframes (Clickjacking protection)
        X-Frame-Options "SAMEORIGIN"
        # HSTS (Strict Transport Security) - tells browsers to ONLY use HTTPS
        Strict-Transport-Security "max-age=31536000; includeSubDomains; preload"
        # "When leaving my site, only tell them the domain name, not the specific page I was on."
        Referrer-Policy "strict-origin-when-cross-origin"
        # Blocks Google's FLoC tracking, but leaves Camera/Mic open
        Permissions-Policy "interest-cohort=()"
    }
    tls {
        protocols tls1.3
    }
}

# A "Loose" CSP for simple apps that don't provide their own
(basic-csp) {
    # Allows scripts/styles from the same domain, plus inline scripts (needed by many dashboards)
    header Content-Security-Policy "default-src 'self'; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; img-src * data: blob:; connect-src *; font-src 'self' data:;"
}

(common-robots) {
    handle /robots.txt {
        root * /srv
        file_server
    }
}

# Plaintext logging
(common-logging-plaintext) {
    log {
        output file /mnt/logs/current/caddy/plaintext/{args[0]}.log {
            roll_size     50MiB
            roll_keep     150
            roll_keep_for 4320h
        }
        # This specifies the plaintext format you were using before
        format transform "{common_log}"
    }
}

# JSON logging for Crowdsec
(common-logging) {
    log {
        output file /mnt/logs/current/caddy/json/{args[0]}.log {
            roll_size     50MiB
            roll_keep     150
            roll_keep_for 4320h
        }
        format json
    }
}

# ---- sites ----
{$DOMAIN_NAME} {
    import common-headers
    import basic-csp
    import common-robots
    import access_policy_wan 100 30s
    import common-logging-plaintext main
    import common-logging main
    import honeypots-and-traps

    redir https://home.{$DOMAIN_NAME}{uri} permanent
}

home.{$DOMAIN_NAME} {
    import common-headers
    # import basic-csp # Breaks embedding from fail2ban app
    import common-robots
    import access_policy_wan 2500 60s
    import common-logging-plaintext home
    import common-logging home
    import honeypots-and-traps

    # reverse_proxy dashy:8080
    reverse_proxy {$HOMELAB_IP}:9102 localhost:8081 {
        lb_policy first
        health_uri /
        health_interval 10s
        health_timeout 2s
    }
}

