status.{$DOMAIN_NAME} {
    import common-headers
    import common-robots
    import common-logging-plaintext uptime-kuma
    import common-logging uptime-kuma

    # 1. Public paths — anyone can access these
    @public_paths {
        path /status/*
        path /assets/*
        path /api/status-page/*
        path /api/status-page/heartbeat/*
        path /icon.png
        path /apple-touch-icon.png
    }

    # 2. Serve public paths directly to the backend
    handle @public_paths {
        reverse_proxy {$HOMELAB_IP}:3003
    }

    # 3. Everything else is restricted to LAN only
    handle {
        import access_policy_lan
        # reverse_proxy uptime-kuma:3001
        reverse_proxy {$HOMELAB_IP}:3003
    }
}

