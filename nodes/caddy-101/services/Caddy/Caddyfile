nextcloud.{$DOMAIN_NAME} {
    # import common-headers
    import common-robots
    import access_policy_wan 4000 60s
    import common-logging-plaintext nextcloud
    import common-logging nextcloud

    header {
            # Fixes HSTS warning (6 months in seconds)
            Strict-Transport-Security "max-age=15552000"
            # Blocks Google's FLoC tracking, but leaves Camera/Mic open for Talk
            Permissions-Policy "interest-cohort=()"
        }

    redir /.well-known/carddav /remote.php/dav 301
    redir /.well-known/caldav /remote.php/dav 301
    redir /.well-known/webfinger /index.php/.well-known/webfinger 301
    redir /.well-known/nodeinfo /index.php/.well-known/nodeinfo 301
    redir /ocm-provider/ /index.php/ocm-provider/ 301

    reverse_proxy {$HOMELAB_IP}:8104
}

