banned.{$DOMAIN_NAME} {
    import common-headers
    import basic-csp
    import common-robots
    import access_policy_wan 200 30s
    import common-logging-plaintext banned
    import common-logging banned

    header {
            # 1. Remove the strict 'SAMEORIGIN' rule from common-headers
            -X-Frame-Options
            
            # 2. Allow embedding only by your specific subdomains (e.g. Dashy)
            Content-Security-Policy "frame-ancestors https://*.{$DOMAIN_NAME}"
        }

    # reverse_proxy fail2ban_monitor:9002 {
    reverse_proxy localhost:9002 {
        header_down -X-Frame-Options
    }
}

