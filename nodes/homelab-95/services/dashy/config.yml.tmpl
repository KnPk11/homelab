pageInfo:
  title: Dash's Homelab Dashboard
  description: |
    Self-hosted at home by an Analytics Engineer with an interest in networking & infrastructure. Stack consists of a mini PC running Proxmox, a Raspberry Pi, a Mikrotik router, and a consumer router.
appConfig:
  disableConfiguration: true
  enableMultiTasking: true
  disableConfigurationForNonAdmin: true
  auth:
    enable: true
    # enableGuestAccess: true
    users:
      - user: Dash
        hash: ${DASHY_AUTH_HASH}
        type: admin
      - user: Services
        hash: ${DASHY_AUTH_HASH}
        type: admin
  layout: vertical
  iconSize: medium
  theme: one-dark
sections:
  - name: Current Usage
    displayData:
      hideForGuests: true
      hideForUsers: ['Services']
      sortBy: default
      rows: 1
      cols: 1
      collapsed: false
    widgets:
      - type: gl-current-cpu
        options:
          label: CPU Usage
          hostname: http://glances:61208
          ignoreErrors: false
          refreshRate: 1000
        useProxy: true

      - type: gl-current-mem
        options:
          label: RAM Usage
          hostname: http://glances:61208
          ignoreErrors: false
        useProxy: true

      - type: gl-disk-space
        options:
          label: Drive Space
          hostname: http://glances:61208
        useProxy: true

      - type: gl-network-interfaces
        options:
          label: Network Interfaces
          hostname: http://glances:61208
          ignoreErrors: false
        useProxy: true

      # - type: gl-disk-io
      #   options:
      #     label: Disk I/O
      #     hostname: http://glances:61208
      #     ignoreErrors: false
      #   useProxy: true

      - type: gl-cpu-temp
        options:
          label: Temps (°C)
          hostname: http://glances:61208
          units: C
        useProxy: true

      - type: gl-alerts
        options:
          label: Resource Usage Alerts
          hostname: http://glances:61208
          updateInterval: 60
        useProxy: true

  - name: Recent System Stats
    displayData:
      hideForUsers: ['Services']
      sortBy: default
      rows: 2
      cols: 1
      collapsed: false
    widgets:
      - type: gl-cpu-history
        options:
          label: CPU Usage History
          hostname: http://glances:61208
          limit: 250
          chartColors:
            - '#9b5de5'
            - '#f15bb5'
            - '#00bbf9'
            - '#00f5d4'
          chartHeight: 300
        useProxy: true

      - type: gl-load-history
        options:
          label: System Load History
          hostname: http://glances:61208
          limit: 250
        useProxy: true

      - type: gl-mem-history
        options:
          label: RAM Usage History
          hostname: http://glances:61208
          limit: 250
        useProxy: true

      - type: gl-network-traffic
        options:
          label: Network Traffic
          hostname: http://glances:61208
          limit: 250
        useProxy: true

  - name: Services
    displayData:
      hideForGuests: true
      hideForUsers: ['Services']
    items:
      - title: Router Web UI
        description: Router Admin
        icon: fas fa-network-wired
        url: https://${ROUTER_IP}:8443
        statusCheck: true
        statusCheckAcceptCodes: '200,204,301,302,307,401,403'

      - title: Proxmox
        description: Virtualization Hypervisor
        icon: fas fa-layer-group
        url: https://${PROXMOX_IP}:8006
        statusCheck: true
        statusCheckAllowInsecure: true

      - title: Cockpit
        description: System Management
        icon: fas fa-tachometer-alt
        url: https://cockpit.${HOMELAB_DOMAIN}
        statusCheck: true

      - title: Uptime Kuma
        description: Uptime & Status Monitoring
